datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model PsaScan {
  id              Int      @id @default(autoincrement())
  url             String   @unique
  urlHash         String   @unique
  pageTitle       String?
  privacyScore    String?
  privacyNote     String?
  securityScore   String?
  securityNote    String?
  ageScore        String?
  ageNote         String?
  hasSchema       Boolean  @default(false)
  hasCookieBanner Boolean  @default(false)
  isPaid          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  expiresAt       DateTime?
}
